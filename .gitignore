## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file is for .NET Core / .NET 5+ projects.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
Log/
[Ll]og/

# Visual Studio 2015/2017/2019/2022 cache and settings
.vs/
# Uncomment if you use Visual Studio Code
#.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image build caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on VFAT partitions
$RECYCLE.BIN/

# VS Code files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCop.Cache

# Backup & report files from converting an old solution file to a newer version of VS
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/
*.rptproj.bak

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.rsuser
*- [Cc]ontainer.user
# Microsoft Fakes
FakesAssemblies/

# GhostDoc plugin setting file
*.GhostDoc.xml

# Node.js / NPM
node_modules/
npm-debug.log
package-lock.json

# Visual Studio Server Explorer bundle resources
Edge/
App_Data/

# Paket dependency manager
.paket/
paket.lock

# FAKE - F# Make
.fake/

# JetBrains Rider
.idea/
*.sln.iml

# CodeRush
.cr/

# Python Tools for Visual Studio (PTVS)
__pycache__/
*.pyc

# Cake
/tools/
!/tools/packages.config

# Tabs Studio
*.tss

# Telerik Agility Toolbox
*.terelik-telemetry.xml

# Bower repositories
bower_components/

# Windows Installer files
*.cab
*.msi
*.msm
*.msp

# Built symbol files
*.pdb

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# Custom NuGet mirror settings
NuGet.Config
# Refactorings
*.Designer.cs
*.g.cs
*.g.i.cs

# Others
.DS_Store

# Standalone Releases
Releases/
